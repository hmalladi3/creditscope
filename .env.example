# @spec DEPLOY-017 — single source of truth for required env var *names* across
# local Docker Compose and the live Vercel/Render/Neon deployment. Values here are
# dev-only placeholders; live secrets are set directly in each platform's dashboard.

# Backend (Render, or docker-compose overrides)
DATABASE_URL=jdbc:postgresql://localhost:5432/creditscope
DATABASE_USERNAME=creditscope
DATABASE_PASSWORD=creditscope
JWT_SECRET=dev-only-secret-do-not-use-in-production-min-32-bytes-long
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Frontend (Vercel, or docker-compose build arg)
VITE_API_BASE_URL=http://localhost:8080
